<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Upcoming Service Projects</h2>
        <ul>
            <% projects.forEach(project=> { %>
                <li><strong>
                        <span><a href="/project/<%= project.project_id %>"><%= project.title %></a> - <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></span>
                    </strong>
                    <p> <%= project.description %></p>
                    <p> <%= project.location %> - <span> <%= project.project_date %></span></p>
                </li>
                <% }) %>
        </ul>
    </main>
    <%- include('partials/footer') %>